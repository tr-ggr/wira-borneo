  "info": {
    "title": "Wira Borneo API",
    "description": "API documentation for local development and client generation",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "SignUpPayload": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "pregnantStatus": {
            "type": "object",
            "nullable": true
          },
          "ageGroup": {
            "type": "string",
            "nullable": true,
            "enum": [
              "UNDER_12",
              "AGE_12_17",
              "AGE_18_59",
              "AGE_60_PLUS"
            ]
          },
          "isPWD": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "AuthenticatedUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "image": {
            "type": "object",
            "nullable": true
          },
          "role": {
            "type": "object",
            "nullable": true
          },
          "pregnantStatus": {
            "type": "object",
            "nullable": true
          },
          "ageGroup": {
            "type": "string",
            "nullable": true,
            "enum": [
              "UNDER_12",
              "AGE_12_17",
              "AGE_18_59",
              "AGE_60_PLUS"
            ]
          },
          "isPWD": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "emailVerified"
        ]
      },
      "SignUpResult": {
        "type": "object",
        "properties": {
          "token": {
            "type": "object",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/AuthenticatedUser"
          }
        },
        "required": [
          "user"
        ]
      },
      "SignInPayload": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SignInResult": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthenticatedUser"
          }
        },
        "required": [
          "token",
          "user"
        ]
      },
      "AuthSession": {
        "type": "object",
        "properties": {
          "session": {
            "type": "object"
          },
          "user": {
            "$ref": "#/components/schemas/AuthenticatedUser"
          }
        },
        "required": [
          "session",
          "user"
        ]
      },
      "UpdateProfilePayload": {
        "type": "object",
        "properties": {
          "pregnantStatus": {
            "type": "object",
            "nullable": true
          },
          "ageGroup": {
            "type": "string",
            "nullable": true,
            "enum": [
              "UNDER_12",
              "AGE_12_17",
              "AGE_18_59",
              "AGE_60_PLUS"
            ]
          },
          "isPWD": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "CreateFamilyDto": {
        "type": "object",
        "properties": {}
      },
      "JoinFamilyDto": {
        "type": "object",
        "properties": {}
      },
      "VolunteerApplicationDto": {
        "type": "object",
        "properties": {}
      },
      "VolunteerHomeDto": {
        "type": "object",
        "properties": {}
      },
      "CreateHelpRequestDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateHelpRequestStatusDto": {
        "type": "object",
        "properties": {}
      },
      "AssistantInquiryDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "What should I do during a flood?",
            "description": "User question (max 500 chars)"
          },
          "location": {
            "type": "string",
            "example": "Kuching",
            "description": "Current location of the user"
          },
          "hazardType": {
            "type": "string",
            "example": "FLOOD",
            "description": "Type of hazard relevant to the inquiry"
          }
        },
        "required": [
          "question"
        ]
      },
      "AssistantStructuredDataDto": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "example": "Move to higher ground immediately.",
            "description": "Brief summary of advice"
          },
          "steps": {
            "example": [
              "Pack a go bag",
              "Listen to radio"
            ],
            "description": "Actionable steps",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "safetyReminder": {
            "type": "string",
            "example": "Stay clear of power lines.",
            "description": "Safety reminder"
          }
        },
        "required": [
          "summary",
          "steps",
          "safetyReminder"
        ]
      },
      "AssistantInquiryResponseDto": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string",
            "example": "Move to higher ground immediately.",
            "description": "AI-generated answer to the inquiry"
          },
          "disclaimer": {
            "type": "string",
            "example": "This is general guidance only. Always follow local authorities.",
            "description": "Disclaimer regarding AI-generated content"
          },
          "provider": {
            "type": "string",
            "example": "sea-lion",
            "description": "The LLM provider that generated the response"
          },
          "structuredData": {
            "description": "Structured formulation of the advice",
            "allOf": [
              {
                "$ref": "#/components/schemas/AssistantStructuredDataDto"
              }
            ]
          }
        },
        "required": [
          "answer",
          "disclaimer",
          "provider"
        ]
      },
      "ReviewVolunteerDto": {
        "type": "object",
        "properties": {}
      },
      "BulkReviewVolunteerDto": {
        "type": "object",
        "properties": {}
      },
      "SuspendReactivateVolunteerDto": {
        "type": "object",
        "properties": {}
      },
      "CreateWarningDto": {
        "type": "object",
        "properties": {}
      },
      "ReviewPinDto": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "APPROVE",
              "REJECT"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "action"
        ]
      },
      "WarningPromptSuggestionDto": {
        "type": "object",
        "properties": {}
      },
      "Object": {
        "type": "object",
        "properties": {}
      },
      "CreatePinDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Short title for the hazard pin"
          },
          "hazardType": {
            "type": "string",
            "enum": [
              "FLOOD",
              "TYPHOON",
              "EARTHQUAKE",
              "AFTERSHOCK"
            ]
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "note": {
            "type": "string"
          },
          "photoUrl": {
            "type": "string"
          },
          "photoKey": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "hazardType",
          "latitude",
          "longitude"
        ]
      },
      "TrackerShipmentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "shipmentId": {
            "type": "string"
          },
          "origin": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "class": {
            "type": "string"
          },
          "blockchainHash": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "DISPATCHED",
              "IN_TRANSIT",
              "DELIVERED"
            ]
          },
          "verificationStatus": {
            "type": "string",
            "enum": [
              "VERIFIED",
              "PENDING",
              "FAILED"
            ]
          },
          "timestamp": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "shipmentId",
          "origin",
          "destination",
          "class",
          "status",
          "verificationStatus",
          "timestamp"
        ]
      },
      "TrackerStatsDto": {
        "type": "object",
        "properties": {
          "totalAidDisbursed": {
            "type": "number"
          },
          "verifiedPayouts": {
            "type": "number"
          },
          "networkTrustIndex": {
            "type": "number"
          }
        },
        "required": [
          "totalAidDisbursed",
          "verifiedPayouts",
          "networkTrustIndex"
        ]
      },
      "TrackerReliefZoneDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "familyCount": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "INACTIVE"
            ]
          },
          "zoneType": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "lat",
          "lng",
          "familyCount",
          "status",
          "zoneType"
        ]
      },
      "TrackerValidatorDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "nodeId": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "latencyMs": {
            "type": "number"
          },
          "uptimePercentage": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "ONLINE",
              "OFFLINE",
              "DEGRADED"
            ]
          }
        },
        "required": [
          "id",
          "nodeId",
          "location",
          "latencyMs",
          "uptimePercentage",
          "status"
        ]
      }
    }
