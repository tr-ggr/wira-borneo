# Path to neighborhood_data.json (from wira-resources/AI Simulation/ or your export).
# Default when run from wira-borneo: workspace root/wira-resources/AI Simulation/neighborhood_data.json
# For monorepo (wira/wira-borneo + wira/wira-resources), set e.g. ../../wira-resources/AI Simulation/neighborhood_data.json
# NEIGHBORHOOD_DATA_PATH=/path/to/neighborhood_data.json

# Server port (default 5001)
# FLASK_PORT=5001

# Walking speed in m/s for duration estimate (default ~5 km/h)
# WALKING_SPEED_MS=1.38888888

# Max distance in meters to snap origin/destination to graph (default 5000)
# MAX_SNAP_DISTANCE_M=5000
