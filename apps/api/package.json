{
  "name": "@wira-borneo/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:format": "prisma format --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:migrate:status": "prisma migrate status --config prisma.config.ts"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/api"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api/dist/package.json",
          "{workspaceRoot}/apps/api/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@wira-borneo/api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@wira-borneo/api:build:development"
          },
          "production": {
            "buildTarget": "@wira-borneo/api:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "prisma-validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run prisma:validate",
          "cwd": "apps/api"
        }
      },
      "prisma-generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run prisma:generate",
          "cwd": "apps/api"
        }
      },
      "prisma-migrate-deploy": {
        "dependsOn": [
          "prisma-generate"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run prisma:migrate:deploy",
          "cwd": "apps/api"
        }
      },
      "prisma-prepare-deploy": {
        "dependsOn": [
          "prisma-generate",
          "prisma-migrate-deploy"
        ],
        "executor": "nx:noop"
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.4",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^6.0.0"
  }
}
