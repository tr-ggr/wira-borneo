generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Greeting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
