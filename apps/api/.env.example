# PostgreSQL connection string used by API runtime (use pooler URL for Supabase with ?pgbouncer=true)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wira_borneo?schema=public"

# Direct connection for migrations and seed (required for Supabase). Get from Dashboard → Database → Connection string → Direct/Session.
# Omit for local dev; Prisma will use DATABASE_URL.
# DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Better Auth runtime configuration
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_BASE_URL="http://localhost:3333"

# Comma-separated origins allowed for cookie-based auth requests
# AUTH_TRUSTED_ORIGINS="http://localhost:4444,http://localhost:3192,http://localhost:8888"

# LLM Server (Flask) — used by the assistant module. Use a different port from hazard server if both run locally.
LLM_SERVER_URL="http://localhost:5000"
# Must match the LLM server's WIRA_INTERNAL_SECRET (required when using the assistant).
LLM_INTERNAL_SECRET=
# LLM_TIMEOUT_MS=15000

# Hazard-aware routing server. Required for AI flood simulation (risk/hazard route). When unset, hazard-route API returns null and no green route is drawn.
# Run wira-hazard-routing-server (e.g. python app.py) and set this URL. Use a different port from LLM_SERVER_URL (e.g. hazard 5001, LLM 5000).
HAZARD_ROUTING_SERVER_URL="http://localhost:5001"
# HAZARD_ROUTING_TIMEOUT_MS=15000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
